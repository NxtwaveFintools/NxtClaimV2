# ─────────────────────────────────────────────────────────────────────────────
# NxtClaim — Environment Variables
# Copy this file to .env.local and fill in your values.
#   cp .env.example .env.local
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Service role key — server-side only, never expose to the client
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ── App ───────────────────────────────────────────────────────────────────────
# Base URL used for Auth redirects (use localhost for local dev)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── AI ────────────────────────────────────────────────────────────────────────
# Google Gemini API key — used for policy/receipt analysis
GEMINI_API_KEY=<your-gemini-api-key>

# Optional. Gemini model used for receipt parsing. Defaults to gemini-3.5-flash.
GEMINI_MODEL=gemini-3.5-flash

# ─────────────────────────────────────────────────────────────────────────────
# Project commands (quick reference)
# ─────────────────────────────────────────────────────────────────────────────

# Check which Supabase project is currently linked:
#   cat supabase/.temp/project-ref

# Link to a Supabase project:
#   npx supabase link --project-ref <project-ref>

# Apply DB migrations:
#   npm run db:migrate          # dry-run preview
#   npm run db:migrate:dry-run  # same, explicit dry-run flag

# Seed master data (departments / HOD routing):
#   npm run seed:master-routing          # preview only
#   npm run seed:master-routing:apply    # apply to DB

# Run dev server:
#   npm run dev

# Run unit tests + coverage:
#   npm run test:unit

# Run e2e tests:
#   npm run test:e2e
