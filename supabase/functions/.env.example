# Business Central — copy this file to supabase/functions/.env and fill in
# real values. Sandbox / test-env values come from the Microsoft Entra ID
# app registration and the BC company GUID. NEVER commit a real .env.
#
# These variables are consumed by:
#   - _shared/bcEnv.ts (validation + caching)
#   - _shared/bcAuth.ts (OAuth2 token retrieval)
#   - _shared/bcClient.ts (URL construction)
#   - bc-claim/index.ts, bc-reference/index.ts

BC_TENANT_ID=00000000-0000-0000-0000-000000000000
BC_CLIENT_ID=00000000-0000-0000-0000-000000000000
BC_CLIENT_SECRET=replace_me
BC_ENVIRONMENT=Sandbox_05052026
BC_COMPANY_ID=00000000-0000-0000-0000-000000000000
BC_COMPANY_NAME=NxtWave

# Optional — comma-separated list of browser origins allowed by the CORS
# check in bc-claim / bc-reference. Empty/missing => browsers blocked;
# server-to-server callers (no Origin header) unaffected.
BC_ALLOWED_ORIGINS=
